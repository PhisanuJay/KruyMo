        <mxCell id="t2" value="KruyMo — Booking Lifecycle (Customer → Staff/Admin)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=20;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="40" y="24" width="760" height="30" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="1. Browse &amp; Book&#xa;Select faculty / size / degree / dates&#xa;Add to cart or book directly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#E63946;fontSize=12;fontColor=#111111;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="2. Payment&#xa;Scan PromptPay QR&#xa;Upload slip + refund account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E63946;fontSize=12;fontColor=#111111;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="90" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="3. Verify Slip&#xa;Staff/Admin review payment&#xa;Approve or reject" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#111111;fontSize=12;fontColor=#111111;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="90" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="4. Prepare &amp; Ship&#xa;Costume checklist&#xa;Assign courier · out for delivery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#111111;fontSize=12;fontColor=#111111;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="90" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="5. Delivered&#xa;Customer confirms receipt&#xa;Use during rental period" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#E63946;fontSize=12;fontColor=#111111;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="90" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="s6" value="6. Return&#xa;Customer submits return&#xa;Staff receives into inventory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E63946;fontSize=12;fontColor=#111111;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="260" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="7. Deposit Refund&#xa;Inspect condition · apply penalty&#xa;Transfer refund + attach slip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#16A34A;fontSize=12;fontColor=#111111;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="260" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="8. Closed&#xa;deposit_refunded&#xa;Rental cycle complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111111;strokeColor=#111111;fontSize=12;fontColor=#FFFFFF;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="260" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E63946;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
