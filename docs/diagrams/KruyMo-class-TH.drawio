        <mxCell id="University" parent="1" style="swimlane;fontStyle=1;align=left;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=40;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=11;" value="«เอนทิตี»&#xa;มหาวิทยาลัย (University)&#xa;———&#xa;+ รหัส: สตริง&#xa;+ ชื่อเต็ม: สตริง&#xa;+ ชื่อย่อ: สตริง" vertex="1">
