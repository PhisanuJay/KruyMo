<mxfile host="app.diagrams.net" agent="KruyMo">
  <diagram id="class-th" name="แผนภาพคลาส (ภาษาไทย)">
    <mxGraphModel dx="2060" dy="1124" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" parent="1" style="text;html=1;fontSize=18;fontStyle=1;fontColor=#111111;" value="KruyMo — แผนภาพคลาส (Class Diagram)&#xa;แบบจำลองโดเมน / โครงสร้างข้อมูล JSON" vertex="1">
          <mxGeometry height="50" width="520" x="140" y="100" as="geometry" />
        </mxCell>
        <mxCell id="User" parent="1" style="swimlane;fontStyle=1;align=left;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=40;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#FFF1F2;strokeColor=#E63946;fontSize=11;" value="«เอนทิตี»&#xa;ผู้ใช้ (User)&#xa;———&#xa;+ รหัส: สตริง&#xa;+ ชื่อ: สตริง&#xa;+ อีเมล: สตริง&#xa;+ รหัสผ่านแฮช: สตริง&#xa;+ เบอร์โทร: สตริง&#xa;+ บทบาท: ลูกค้า|พนักงาน|แอดมิน&#xa;+ ยืนยันอีเมลแล้ว: บูลีน&#xa;+ ที่อยู่: ที่อยู่จัดส่ง&#xa;+ บัญชีคืนมัดจำ: บัญชีรับเงิน" vertex="1">
          <mxGeometry height="230" width="250" x="140" y="174" as="geometry" />
        </mxCell>
        <mxCell id="Booking" parent="1" style="swimlane;fontStyle=1;align=left;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=40;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#FFFFFF;strokeColor=#111111;fontSize=11;" value="«เอนทิตี»&#xa;การจอง (Booking)&#xa;———&#xa;+ รหัส: สตริง&#xa;+ รหัสผู้ใช้: สตริง&#xa;+ รหัสชุดครุย: สตริง&#xa;+ รหัสไซส์: สตริง&#xa;+ ระดับปริญญา: สตริง&#xa;+ วันเริ่มเช่า: วันที่&#xa;+ วันสิ้นสุดเช่า: วันที่&#xa;+ สถานะ: สตริง&#xa;+ ค่าเช่า: จำนวน&#xa;+ เงินมัดจำ: จำนวน&#xa;+ ยอดรวม: จำนวน&#xa;+ ที่อยู่จัดส่ง: ที่อยู่จัดส่ง&#xa;+ แมสเซนเจอร์: ข้อมูลแมสฯ&#xa;+ บัญชีคืนมัดจำ: บัญชีรับเงิน" vertex="1">
          <mxGeometry height="300" width="270" x="480" y="174" as="geometry" />
        </mxCell>
        <mxCell id="Payment" parent="1" style="swimlane;fontStyle=1;align=left;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=40;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#FFFFFF;strokeColor=#111111;fontSize=11;" value="«เอนทิตี»&#xa;การชำระเงิน (Payment)&#xa;———&#xa;+ รหัส: สตริง&#xa;+ รหัสการจอง: สตริง&#xa;+ ยอดชำระ: จำนวน&#xa;+ รูปสลิป: สตริง&#xa;+ สถานะ: รอตรวจ|ยืนยัน|ปฏิเสธ&#xa;+ บัญชีคืนมัดจำ: บัญชีรับเงิน" vertex="1">
          <mxGeometry height="180" width="250" x="840" y="174" as="geometry" />
        </mxCell>
        <mxCell id="Cart" parent="1" style="swimlane;fontStyle=1;align=left;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=40;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#EFF6FF;strokeColor=#3B82F6;fontSize=11;" value="«เอนทิตี»&#xa;รายการตะกร้า (CartItem)&#xa;———&#xa;+ รหัส: สตริง&#xa;+ รหัสผู้ใช้: สตริง&#xa;+ รหัสชุดครุย: สตริง&#xa;+ รหัสไซส์: สตริง&#xa;+ ระดับปริญญา: สตริง&#xa;+ วันเริ่มเช่า: วันที่&#xa;+ วันสิ้นสุดเช่า: วันที่" vertex="1">
          <mxGeometry height="200" width="240" x="1180" y="174" as="geometry" />
        </mxCell>
        <mxCell id="Costume" parent="1" style="swimlane;fontStyle=1;align=left;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=40;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#ECFDF5;strokeColor=#16A34A;fontSize=11;" value="«เอนทิตี»&#xa;ชุดครุย (Costume)&#xa;———&#xa;+ รหัส: สตริง&#xa;+ ชื่อชุด: สตริง&#xa;+ รหัสมหาวิทยาลัย: สตริง&#xa;+ รหัสคณะ: สตริง&#xa;+ ราคาต่อวัน: จำนวน&#xa;+ เงินมัดจำ: จำนวน&#xa;+ จำนวนในคลัง: จำนวน&#xa;+ รูปภาพ: สตริง[]" vertex="1">
          <mxGeometry height="210" width="240" x="480" y="544" as="geometry" />
