        <mxCell id="Inventory" parent="1" style="swimlane;fontStyle=1;align=left;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=40;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#ECFDF5;strokeColor=#16A34A;fontSize=11;" value="«เอนทิตี»&#xa;รายการสต็อก (InventoryItem)&#xa;———&#xa;+ รหัสชุดครุย: สตริง&#xa;+ รหัสไซส์: สตริง&#xa;+ ระดับปริญญา: ตรี|โท|เอก&#xa;+ จำนวนคงเหลือ: จำนวน" vertex="1">
          <mxGeometry height="150" width="250" x="800" y="544" as="geometry" />
