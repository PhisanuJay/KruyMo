        <mxCell id="Size" parent="1" style="swimlane;fontStyle=1;align=left;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=40;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#F3F4F6;strokeColor=#6B7280;fontSize=11;" value="«เอนทิตี»&#xa;ไซส์ (Size)&#xa;———&#xa;+ รหัส: สตริง&#xa;+ ป้ายไซส์: สตริง&#xa;+ ส่วนสูงต่ำสุด: จำนวน&#xa;+ ส่วนสูงสูงสุด: จำนวน" vertex="1">
