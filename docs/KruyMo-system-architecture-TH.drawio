        <mxCell id="s6" value="6. ส่งคืน&#xa;ลูกค้าแจ้งส่งคืน&#xa;พนักงานรับเข้าคลัง" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E63946;fontSize=12;fontColor=#111111;arcSize=10;" vertex="1" parent="1">
