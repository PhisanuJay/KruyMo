        </mxCell>
        <mxCell id="s7" value="7. คืนมัดจำ&#xa;ตรวจสภาพ · หักค่าปรับ&#xa;โอนคืน + แนบสลิป" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#16A34A;fontSize=12;fontColor=#111111;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="260" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="8. ปิดงาน&#xa;คืนมัดจำแล้ว&#xa;จบวงจรการเช่า" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111111;strokeColor=#111111;fontSize=12;fontColor=#FFFFFF;arcSize=10;" vertex="1" parent="1">
